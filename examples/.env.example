# Used by ara_sdk CLI auth for deploy/setup/run commands in examples/README.md.
ARA_API_KEY=

# Used by send_email() in examples/02-canonical-email-chat-cron.py.
RESEND_API_KEY=
CRON_EMAIL_FROM=noreply@example.com

# Used by App(...) initialization in examples/02-canonical-email-chat-cron.py.
ARA_DEMO_APP_SLUG=canonical-email-chat-cron-demo
ARA_DEMO_CHAT_AGENT_ID=demo-chat

# Used by App(..., interfaces={\"inherit_owner_tools\": ...}) in examples/02-canonical-email-chat-cron.py.
ARA_DEMO_INHERIT_OWNER_TOOLS=false

# Used by frontend/02-canonical-email-chat-cron/main.js for direct runtime API calls.
# API base URL is fixed in code to https://api.ara.so.
VITE_ARA_APP_ID=
VITE_ARA_RUNTIME_KEY=
VITE_ARA_CHAT_AGENT_ID=demo-chat
VITE_ARA_EXTRA_INPUT_JSON=
